from __future__ import annotations

import hashlib, json, random
from pathlib import Path
from typing import Any

SCHEMA_VERSION="1.1.0"
GENERATOR_VERSION="sim-0.3.1"
SOURCE_PACK_VERSION="rs_source_pack_v1.1"
DEFAULT_TASK_ID="RS-EN-001"
DEFAULT_WORKFLOW_ID="wf_RS-EN-001_engine_lifecycle_provenance"
DATA_CLASSIFICATION="INTERNAL_SIM"
BUSINESS_DAY="2026-01-15"
CREATED_AT="2026-01-15T00:00:00Z"
SOURCE="restaurant_daily_flow_simulator"
SCENARIOS=["normal_day","slow_day","rush_day","weather_disruption","staffing_call_off","equipment_failure","local_event_surge","school_event_surge","holiday_pattern","multi_rush_condition"]
EVENT_TYPES=["order.created","item.taken","item.completed","ticket.updated","staff.assignment.updated","prep.confirmed","waste.recorded","station.overloaded","station.recovered","shift.started","shift.ended"]
DAYPARTS=[("breakfast",360,600,.18,480),("mid_morning",600,690,.07,630),("lunch",690,840,.30,750),("afternoon",840,990,.10,930),("dinner",990,1230,.30,1095),("late_night",1230,1439,.05,1320)]
CHANNELS=["drive_thru","lobby","mobile","delivery"]
MENU={"breakfast_main":("main",["grill","assembly"],{"main_protein":1.0,"prep_pack":.25},{"grill":2.2,"assembly":.8}),"grilled_main":("main",["grill","assembly"],{"main_protein":1.0,"prep_pack":.5},{"grill":2.4,"assembly":1.0}),"fried_main":("main",["fryer","assembly"],{"main_protein":1.0,"prep_pack":.5},{"fryer":2.8,"assembly":1.0}),"side":("side",["fryer"],{"side_base":1.0},{"fryer":1.2}),"beverage":("beverage",["beverage"],{"drink_mix":.25},{"beverage":.5}),"dessert":("dessert",["assembly"],{"prep_pack":.25},{"assembly":.6})}
STATIONS={"grill":(75.0,1.08,.82),"fryer":(85.0,1.08,.82),"assembly":(95.0,1.10,.84),"beverage":(115.0,1.12,.85)}
OPENING={"main_protein":520.0,"side_base":420.0,"drink_mix":300.0,"prep_pack":260.0}
THRESHOLD={"main_protein":120.0,"side_base":95.0,"drink_mix":60.0,"prep_pack":60.0}

def _tuning(s:str)->dict[str,Any]:
    base={"daily":920,"demand":1.0,"staff":1.0,"equip":{},"weather":"clear","traffic":"normal","event":1.0,"shift":{},"waste":1.0,"calloff":False,"local":None}
    data={"slow_day":{"daily":620,"demand":.78,"traffic":"low","shift":{"lobby":.04},"waste":1.35},"rush_day":{"daily":1180,"demand":1.16,"traffic":"high","event":1.08,"shift":{"drive_thru":.04}},"weather_disruption":{"daily":760,"demand":.86,"weather":"storm","shift":{"drive_thru":.08,"delivery":.07,"lobby":-.13},"waste":1.18},"staffing_call_off":{"staff":.74,"calloff":True},"equipment_failure":{"daily":880,"demand":.98,"equip":{"fryer":.55},"waste":1.22},"local_event_surge":{"daily":1050,"demand":1.06,"traffic":"high","event":1.18,"shift":{"drive_thru":.07,"lobby":.03},"local":"community"},"school_event_surge":{"daily":980,"demand":1.03,"traffic":"high","event":1.14,"shift":{"lobby":.08,"drive_thru":.03},"local":"school"},"holiday_pattern":{"daily":840,"demand":.95,"staff":.92,"event":1.08,"shift":{"delivery":.05,"mobile":.04},"waste":1.28,"local":"holiday"},"multi_rush_condition":{"daily":1240,"demand":1.18,"staff":.78,"equip":{"fryer":.70,"beverage":.82},"weather":"rain","traffic":"high","event":1.22,"shift":{"drive_thru":.08,"delivery":.06},"waste":1.25,"calloff":True,"local":"sports"}}
    base.update(data.get(s,{})); return base

def _seed(s:str,seed:int)->int: return int(hashlib.sha256(f"{s}:{seed}".encode()).hexdigest()[:12],16)
def _hhmm(m:int)->str: return f"{m//60:02d}:{m%60:02d}"
def _iso(m:int)->str: return f"{BUSINESS_DAY}T{_hhmm(m)}:00Z"
def _daypart(m:int)->str:
    for n,a,b,_,_ in DAYPARTS:
        if a<=m<b: return n
    return "late_night"
def _part(n:str): return next(p for p in DAYPARTS if p[0]==n)
def _norm(d:dict[str,float])->dict[str,float]:
    c={k:max(0.0,v) for k,v in d.items()}; t=sum(c.values()) or 1.0; return {k:v/t for k,v in c.items()}
def _choice(rng:random.Random,mix:dict[str,float])->str:
    x=rng.random(); total=0.0; last=next(iter(mix))
    for k,v in mix.items():
        total+=v; last=k
        if x<=total: return k
    return last

def _channel_mix(daypart:str,t:dict[str,Any])->dict[str,float]:
    base={"breakfast":{"drive_thru":.68,"lobby":.13,"mobile":.12,"delivery":.07},"mid_morning":{"drive_thru":.55,"lobby":.16,"mobile":.17,"delivery":.12},"lunch":{"drive_thru":.52,"lobby":.20,"mobile":.16,"delivery":.12},"afternoon":{"drive_thru":.48,"lobby":.17,"mobile":.20,"delivery":.15},"dinner":{"drive_thru":.50,"lobby":.18,"mobile":.15,"delivery":.17},"late_night":{"drive_thru":.58,"lobby":.08,"mobile":.14,"delivery":.20}}[daypart].copy()
    for k,v in t["shift"].items(): base[k]=base.get(k,0)+v
    return _norm(base)

def _menu_mix(daypart:str)->dict[str,float]:
    if daypart in {"breakfast","mid_morning"}: return _norm({"breakfast_main":.56,"beverage":.34,"side":.05,"dessert":.05})
    if daypart=="afternoon": return _norm({"grilled_main":.25,"fried_main":.27,"side":.22,"beverage":.18,"dessert":.08})
    if daypart=="late_night": return _norm({"grilled_main":.24,"fried_main":.36,"side":.19,"beverage":.14,"dessert":.07})
    return _norm({"grilled_main":.31,"fried_main":.31,"side":.20,"beverage":.14,"dessert":.04})

def _prov(sim_id:str,scn_id:str,seed:int)->dict[str,Any]:
    return {"simulation_id":sim_id,"scenario_id":scn_id,"seed":seed,"schema_version":SCHEMA_VERSION,"generator_version":GENERATOR_VERSION,"source_pack_version":SOURCE_PACK_VERSION,"task_id":DEFAULT_TASK_ID,"workflow_id":DEFAULT_WORKFLOW_ID,"created_at":CREATED_AT,"synthetic_data":True,"data_classification":DATA_CLASSIFICATION}

def scenario_config(scenario_type:str="normal_day",seed:int=12345)->dict[str,Any]:
    if scenario_type not in SCENARIOS: raise ValueError(f"Unsupported scenario_type: {scenario_type}")
    t=_tuning(scenario_type); scn=f"scn_{scenario_type}"; sim=f"sim_{scenario_type}_{seed}"
    dayparts=[{"daypart":n,"window":{"start":_hhmm(a),"end":_hhmm(b)},"arrival_curve":{"curve_type":"single_peak","base_rate_per_15_min":round(t["daily"]*share/max(1,(b-a)/15),3),"peak_multiplier":1.3,"noise_band":.08},"channel_mix":_channel_mix(n,t),"menu_mix":_menu_mix(n),"basket_size":{"type":"triangular","min":1,"max":5,"mean":2.4},"waste_risk_multiplier":t["waste"]} for n,a,b,share,_ in DAYPARTS]
    return {**_prov(sim,scn,seed),"scenario_name":scenario_type.replace("_"," ").title(),"scenario_type":scenario_type,"restaurant_archetype":{"archetype_id":"qsr_generic_drive_thru_hybrid","service_model":"hybrid","brand_specific":False,"baseline_volume_class":"high" if t["daily"]>=1000 else "medium"},"operating_date_profile":{"business_day":BUSINESS_DAY,"weekday":"thursday","holiday_flag":scenario_type=="holiday_pattern","school_day_flag":scenario_type!="holiday_pattern"},"operating_hours":{"start":"06:00","end":"23:59"},"dayparts":dayparts,"channels":[{"channel":c,"enabled":True,"arrival_multiplier":_channel_mix("lunch",t)[c],"service_time_seconds":{"type":"triangular","min":60,"max":480,"mean":210},"delay_sensitivity":.70 if c=="drive_thru" else .45} for c in CHANNELS],"menu_catalog":{"catalog_id":"generic_qsr_menu_v1","brand_specific":False,"items":[{"item_id":k,"item_category":v[0],"station_ids":v[1],"prep_inventory_draw":v[2],"event_lifecycle":["item.taken","item.completed"],"daypart_availability":[d[0] for d in DAYPARTS]} for k,v in MENU.items()]},"station_model":{"model_id":"generic_qsr_stations_v1","stations":[{"station_id":k,"station_name":k.title(),"capacity_units_per_minute":v[0]/15,"overload_threshold":v[1],"recovery_threshold":v[2]} for k,v in STATIONS.items()]},"staffing_plan":{"plan_id":"generic_qsr_staffing_v1","role_windows":[{"role_id":"manager","station_id":"floor","window":{"start":"06:00","end":"23:59"},"capacity_multiplier":1.0,"synthetic_worker_ref":"manager_on_duty"},{"role_id":"cook","station_id":"grill","window":{"start":"06:00","end":"23:59"},"capacity_multiplier":1.0,"synthetic_worker_ref":"cook_role_01"},{"role_id":"runner","station_id":"drive_thru","window":{"start":"06:00","end":"23:59"},"capacity_multiplier":1.0,"synthetic_worker_ref":"runner_role_01"}]},"prep_inventory_model":{"model_id":"generic_qsr_prep_v1","items":[{"inventory_item_id":k,"opening_quantity":v,"unit":"units","holding_minutes":240,"reorder_threshold":THRESHOLD[k]} 