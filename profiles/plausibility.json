    "afternoon",
    "dinner",
    "late_night"
  ],
  "required_channels": [
    "drive_thru",
    "lobby",
    "mobile",
    "delivery"
  ],
  "required_event_types": [
    "order.created",
    "item.taken",
    "item.completed",
    "ticket.updated",
    "staff.assignment.updated",
    "prep.confirmed",
    "waste.recorded",
