  "thresholds": {
    "minimum_completion_ratio": 0.9,
    "maximum_abandonment_ratio": 0.08,
    "minimum_distinct_daypart_rates": 4,
    "minimum_channel_coverage": 4,
    "minimum_inventory_components": 4,
    "minimum_staffing_entries": 3,
    "minimum_recommendation_rows": 1,
    "minimum_alert_rows": 1,
    "maximum_allowed_labor_percent": 35.0,
    "minimum_average_check_usd": 9.0,
    "maximum_average_check_usd": 13.0
