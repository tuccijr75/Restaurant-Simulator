    "slow_day",
    "rush_day",
    "weather_disruption",
    "staffing_call_off",
    "equipment_failure",
    "local_event_surge",
    "school_event_surge",
    "holiday_pattern",
    "multi_rush_condition"
  ],
  "required_dayparts": [
